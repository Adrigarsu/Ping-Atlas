# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=pingatlas
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pingatlas

# ── Probe configuration ───────────────────────────────────────────────────────
# Seconds between automatic probe runs
PROBE_INTERVAL_SECONDS=300

# Comma-separated list of hostnames or IPs to probe
PROBE_TARGETS=8.8.8.8,1.1.1.1,9.9.9.9

# Latency increase (ms) that triggers a suboptimal route alert
LATENCY_ALERT_DELTA_MS=50

# Maximum TTL hops for traceroute
MAX_HOPS=30